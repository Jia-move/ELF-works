# Smart Guide Web - 环境变量模板
# 复制为 .env 后填入实际值，不要将真实密钥提交到 Git

# 数据库路径（SQLite 文件路径，相对于 backend/）
DATABASE_URL=sqlite:///./data/smart_guide.db

# JWT 密钥（当前演示不启用 JWT，预留配置）
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 服务配置
HOST=127.0.0.1
PORT=8000

# CORS 允许的源
CORS_ORIGINS=http://localhost:8081
